# --- MASTER SECURITY HARDENING ---
# Use a dedicated JWT secret for master accounts.
MASTER_JWT_SECRET=change_this_to_a_long_random_secret
MASTER_PREAUTH_TTL=10m
MASTER_EMAIL_OTP_TTL=10m

# Restrict master login to your email(s) only (comma-separated, lowercase recommended).
MASTER_ALLOWED_EMAILS=admin@edunexus.fr

# Optional: Restrict master login endpoint by source IP (comma-separated).
# Include localhost values for local development.
MASTER_LOGIN_IP_ALLOWLIST=127.0.0.1,::1

# Set to true when backend is behind reverse proxy/load balancer.
TRUST_PROXY=false

# Admin bootstrap variables used by backend/create-admin.ts.
MASTER_MONGO_URL=mongodb://localhost:27017/edunexus_master
MASTER_ADMIN_EMAIL=admin@edunexus.fr
MASTER_ADMIN_PASSWORD=change_this_to_a_strong_password
MASTER_ADMIN_NAME=Platform Administrator
